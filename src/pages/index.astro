---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Octocat from "../components/Octocat.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import Code from "../components/Code.astro"
import bashtxt from "../examples/bash.txt?raw";
import ctxt from "../examples/c.txt?raw";
import cljtxt from "../examples/clj.txt?raw";
import jstxt from "../examples/js.txt?raw";
import luatxt from "../examples/lua.txt?raw";
import rusttxt from "../examples/rust.txt?raw";
import vimtxt from "../examples/vim.txt?raw";
import Headline from "../components/Headline.astro";

const languages = [
  {
    id: "c",
    name: "C",
    code: ctxt,
    language: "c"
  },
  {
    id: "js",
    name: "JavaScript",
    code: jstxt,
    language: "js"
  },
  {
    id: "clj",
    name: "Clojure",
    code: cljtxt,
    language: "clj",
  },
  {
    id: "lua",
    name: "Lua",
    code: luatxt,
    language: "lua"
  },
  {
    id: "rust",
    name: "Rust",
    code: rusttxt,
    language: "rust"
  },
  {
    id: "bash",
    name: "Bash",
    code: bashtxt,
    language: "bash"
  },
  {
    id: "vim",
    name: "Vim",
    code: vimtxt,
    language: "vim"
  },
];
---

<BaseLayout
  title="Srcery Theme - Syntax theme with clearly defined contrasting colors and a slightly earthy tone"
  description="Homepage to the Srcery syntax theme"
>
  <Octocat />
  <div class="flex grow justify-center p-4">
    <main
      class="flex max-w-[448px] min-w-0 flex-col items-center sm:max-w-[780px]"
    >
      <Header />
      <section class="w-full flex flex-col gap-10">
        <div class="text-justify">
          <p class="mb-4">
            Srcery is dark syntax highlighting color scheme with clearly defined
            contrasting colors and a slightly earthy tone.
          </p>
          <p class="text-white">
            Created using colors that logically adheres to the 16 color base
            palette of a terminal, while trying to retain its own identity. The
            colors are designed to be easy on the eyes, yet contrast well with
            the background for long sessions using an editor or terminal
            emulator.
          </p>
        </div>
        <div class="w-full">
          <div class="flex flex-col gap-2 mb-8">
            <Headline title="Preview"></Headline>
            <p class="text-white">
            Here's a few
            <a class="link" href="https://rosettacode.org/wiki/Rosetta_Code"
              >Rosetta Code</a
            >
            examples demoed using
            <a class="link" href="https://highlightjs.org/">highlight.js</a>.
            It'll give a general impression but see the
            <a href="/themes/" class="link">themes</a>
            for details about a specific editor/IDE.
            </p>
          </div>
          <ul
            class="flex overflow-x-auto overflow-y-hidden border-bright-black text-center"
          >
            {
              languages.map((lang, i) => (
                <li class="flex flex-1">
                  <a
                    href="#"
                    class={`tab ${i === 0 ? "tab-active" : "tab-inactive"}`}
                    data-tab={lang.id}
                  >
                    {lang.name}
                  </a>
                </li>
              ))
            }
          </ul>
          <div
            class="overflow-x-auto border-x-1 border-b-1 border-bright-black"
          >
            {
              languages.map((lang, i) => (
                <pre
                  id={`preview-${lang.id}`}
                  class={`flex p-4${i !== 0 ? " hidden" : ""}`}
                >
                  <Code code={lang.code} language={lang.language} />
                </pre>
              ))
            }
          </div>
        </div>
      </section>
    </main>
  </div>
  <Footer />
</BaseLayout>

<script>
  const tabs = document.querySelectorAll<HTMLAnchorElement>("[data-tab]");
  const previews = document.querySelectorAll<HTMLElement>("[id^='preview-']");

  tabs.forEach((tab) => {
    tab.addEventListener("click", (e) => {
      e.preventDefault();
      const id = tab.dataset.tab;

      tabs.forEach((t) => {
        t.className = t === tab ? "tab tab-active" : "tab tab-inactive";
      });

      previews.forEach((p) => {
        p.classList.toggle("hidden", p.id !== `preview-${id}`);
      });
    });
  });
</script>

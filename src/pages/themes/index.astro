---
import steamsvg from "@fortawesome/fontawesome-free/svgs/brands/steam.svg?raw";
import shellsvg from "@fortawesome/fontawesome-free/svgs/solid/file-invoice-dollar.svg?raw";
import guisvg from "@fortawesome/fontawesome-free/svgs/solid/image.svg?raw";
import bashsvg from "devicon/icons/bash/bash-plain.svg?raw";

import vimsvg from "devicon/icons/vim/vim-plain.svg?raw";
import vscodesvg from "devicon/icons/vscode/vscode-plain.svg?raw";
import emacssvg from "simple-icons/icons/gnuemacs.svg?raw";
import insomniasvg from "simple-icons/icons/insomnia.svg?raw";
import intellijsvg from "simple-icons/icons/intellijidea.svg?raw";
import obsidiansvg from "simple-icons/icons/obsidian.svg?raw";
import tmuxsvg from "simple-icons/icons/tmux.svg?raw";
import zedsvg from "simple-icons/icons/zedindustries.svg?raw";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import Card from "../../components/Card.astro";
import Octocat from "../../components/Octocat.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import novasvg from "../../svg/nova.svg?raw";

const themes = [
  {
    name: "vim",
    icon: vimsvg,
    url: "https://www.vim.org/",
    repo: "https://github.com/srcery-colors/srcery-vim",
    download:
      "https://github.com/srcery-colors/srcery-vim/archive/refs/heads/master.zip",
    keywords: ["vim", "vimrc", "neovim", "gvim", "terminal"],
    new: false,
  },
  {
    name: "emacs",
    icon: emacssvg,
    url: "https://www.gnu.org/software/emacs/",
    repo: "https://github.com/srcery-colors/srcery-emacs",
    download:
      "https://github.com/srcery-colors/srcery-emacs/archive/refs/heads/master.zip",
    keywords: ["emacs", "gnu", "terminal", "init.el", "lisp"],
    new: false,
  },
  {
    name: "vscode",
    icon: vscodesvg,
    url: "https://code.visualstudio.com/",
    repo: "https://github.com/srcery-colors/srcery-vscode",
    download:
      "https://marketplace.visualstudio.com/items?itemName=srcery-colors.srcery-colors",
    keywords: ["visual studio", "vscode", "microsoft", "code", "windows"],
    new: false,
  },
  {
    name: "intellij",
    icon: intellijsvg,
    url: "https://www.jetbrains.com/idea/",
    repo: "https://github.com/srcery-colors/srcery-intellij",
    download: "https://plugins.jetbrains.com/plugin/18428-srcery-colorscheme/",
    keywords: ["idea", "java", "intellij", "ide"],
    new: false,
  },
  {
    name: "tmux",
    icon: tmuxsvg,
    url: "https://github.com/tmux/tmux",
    repo: "https://github.com/srcery-colors/srcery-tmux",
    download:
      "https://github.com/srcery-colors/srcery-tmux/archive/refs/heads/master.zip",
    keywords: ["tmux", "terminal", "multiplexer"],
    new: false,
  },
  {
    name: "terminals",
    icon: bashsvg,
    url: "https://en.wikipedia.org/wiki/List_of_terminal_emulators",
    repo: "https://github.com/srcery-colors/srcery-terminal",
    download:
      "https://github.com/srcery-colors/srcery-terminal/archive/refs/heads/master.zip",
    keywords: [
      "terminal",
      "alacritty",
      "blink",
      "chrome secure shell",
      "foot",
      "genode",
      "16 colors",
      "gnome",
      "guake",
      "iterm",
      "kitty",
      "konsole",
      "linux",
      "virtual console",
      "lxterminal",
      "mintty",
      "pantheon",
      "putty",
      "st",
      "terminator",
      "termite",
      "termux",
      "tilix",
      "windows",
      "xfce",
      "xresources",
      "x11",
      "xorg",
    ],
    new: false,
  },
  {
    name: "steam",
    icon: steamsvg,
    url: "https://www.steampowered.com",
    repo: "https://github.com/srcery-colors/srcery-steam-themes",
    download:
      "https://github.com/srcery-colors/srcery-steam-themes/archive/refs/heads/main.zip",
    keywords: ["steam", "steamos", "valve", "gaming", "steamdeck"],
    new: false,
  },
  {
    name: "insomnia",
    icon: insomniasvg,
    url: "https://insomnia.rest/",
    repo: "https://github.com/srcery-colors/srcery-insomnia",
    download:
      "https://github.com/srcery-colors/srcery-insomnia/archive/refs/heads/main.zip",
    keywords: ["insomnia", "rest", "api"],
    new: false,
  },
  {
    name: "zed",
    icon: zedsvg,
    url: "https://zed.dev/",
    repo: "https://github.com/srcery-colors/srcery-zed",
    download:
      "https://github.com/srcery-colors/srcery-zed/archive/refs/heads/main.zip",
    keywords: ["zed", "ai", "rust"],
    new: false,
  },
  {
    name: "obsidian",
    icon: obsidiansvg,
    url: "https://obsidian.md/",
    repo: "https://github.com/srcery-colors/srcery-obsidian",
    download:
      "https://github.com/srcery-colors/srcery-obsidian/archive/refs/heads/main.zip",
    keywords: ["obsidian", "note", "markdown", "md"],
    new: true,
  },
  {
    name: "nova",
    icon: novasvg,
    url: "https://nova.app/",
    repo: "https://github.com/srcery-colors/srcery-nova",
    download:
      "https://github.com/srcery-colors/srcery-nova/archive/refs/heads/main.zip",
    keywords: ["nova", "panic", "apple", "macos"],
    new: true,
  },
  {
    name: "gui themes",
    icon: guisvg,
    url: undefined,
    repo: "https://github.com/srcery-colors/srcery-gui",
    download:
      "https://github.com/srcery-colors/srcery-gui/archive/refs/heads/master.zip",
    keywords: [
      "awesomewm",
      "bspwm",
      "i3wm",
      "oomox",
      "polybar",
      "qutebrowser",
      "rofi",
      "slack",
      "zathura",
    ],
    new: false,
  },
  {
    name: "shell themes",
    icon: shellsvg,
    url: undefined,
    repo: "https://github.com/srcery-colors/srcery-shell",
    download:
      "https://github.com/srcery-colors/srcery-shell/archive/refs/heads/master.zip",
    keywords: ["broot", "cmus", "mutt", "newsboat", "vifm", "zellij"],
    new: false,
  },
];
---

<BaseLayout
  title="Srcery Theme - Themes and configurations"
  description="Search for Srcery implementations, themes, and configurations"
>
  <Octocat />
  <div class="flex grow justify-center p-4">
    <main
      class="flex max-w-[448px] w-full min-w-0 flex-col items-center sm:max-w-[780px]"
    >
      <Header activePage="themes" />
      <section class="flex w-full flex-col">
        <form class="flex justify-center">
          <div class="relative mb-8 w-full max-w-sm sm:max-w-full">
            <div
              class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3"
            >
              <svg
                aria-hidden="true"
                class="h-5 w-5 text-bright-black"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
              </svg>
            </div>
            <input
              id="theme-search"
              type="search"
              class="block w-full border-1 border-bright-black bg-gray2 p-4 pl-10 text-sm text-bright-white placeholder-bright-black focus:border-bright-white focus:outline-hidden"
              placeholder="Search for a theme, configuration, or application..."
            />
          </div>
        </form>
        <div
          class="grid grid-cols-2 justify-items-center gap-5 sm:grid-cols-3 md:grid-cols-4"
        >
          {
            themes.map((theme) => (
            <Card name={theme.name} keywords={theme.keywords}>
            {theme.new ? (
            <span class="absolute top-2.5 right-2.5 text-[9px] uppercase text-[#1e1e1e] bg-bright-black py-0.5 px-1.5 -translate-y-1 transition-all duration-300">
              New
            </span>
            ) : null}
            <div class="flex flex-col w-full gap-3 items-center">
              <div
                class="theme-icon flex h-18 w-18 justify-center svg [&>svg]:max-h-full [&>svg]:max-w-full"
                set:html={theme.icon}
                ></div>
              <span class="text-lg font-bold uppercase text-yellow">
                {theme.name}
              </span>
              <div class="w-full h-px divider" />
                <a
                  href={theme.repo}
                  target="_blank"
                  class="text-[11px] tracking-[2px] uppercase no-underline py-1.5 px-4 border border-transparent w-full text-center text-white transition-[color,border-color,background-color] duration-200 relative hover:text-bright-white hover:border-bright-black hover:bg-xgray1"
                  >
                  repository
                </a>
                  <a
                    href={theme.download}
                    target="_blank"
                    class="text-[11px] tracking-[2px] uppercase no-underline py-1.5 px-4 border border-transparent w-full text-center text-white transition-[color,border-color,background-color] duration-200 relative hover:text-bright-white hover:border-bright-black hover:bg-xgray1"
                    >
                    download
                  </a>
              </div>
              </Card>
            ))
          }
        </div>
      </section>
    </main>
  </div>
  <Footer />
</BaseLayout>

<style>
  .divider {
    background: linear-gradient(
      90deg,
      transparent,
      var(--color-white),
      transparent
        );
  }

</style>

<script>
  const input = document.getElementById("theme-search") as HTMLInputElement;
  const cards = document.querySelectorAll<HTMLElement>(".card");

  input.addEventListener("input", () => {
    const q = input.value.toLowerCase();
    cards.forEach((card) => {
      const name = (card.dataset.name ?? "").toLowerCase();
      const keywords = (card.dataset.keywords ?? "").toLowerCase();
      card.hidden = q !== "" && !name.includes(q) && !keywords.includes(q);
    });
  });
</script>

---
interface Props {
  title: string;
  color?: string;
  text_size?: string;
  subtitle?: boolean;
  id?: string;
}

const {
  title,
  color = "color-bright-white",
  text_size = "text-base",
  subtitle = false,
  id,
} = Astro.props;

const anchorId = id ?? title.toLowerCase().replace(/\s+/g, "-");
---

<div class="flex items-center gap-2 flex-wrap" id={anchorId}>
  <a
    href={`#${anchorId}`}
    class="flex items-center gap-2 uppercase font-bold no-underline transition-opacity group"
  >
    <span
      class:list={[
        "text-bright-black group-hover:text-bright-yellow",
        text_size,
      ]}>#</span
    >
    <span class:list={["group-hover:text-bright-yellow", text_size, color]}
      >{title}</span
    >
  </a>
  {!subtitle ? <div class="flex-1 section-line h-[1px]" /> : null}
  <slot />
</div>

<style>
  .section-line {
    background: linear-gradient(90deg, var(--color-bright-black), transparent);
  }
</style>

{
  "name": "srcery-colors-website",
  "version": "4.0.0",
  "private": true,
  "description": "Srcery theme landing page",
  "homepage": "https://srcery.sh",
  "repository": {
    "type": "git",
    "url": "https://github.com/srcery-colors/srcery.sh"
  },
  "license": "MIT",
  "author": "Srcery Team",
  "type": "module",
  "browser": true,
  "scripts": {
    "build": "astro build",
    "check": "astro check && tsc --noEmit",
    "clean": "rm -f src/github.json",
    "dev": "astro dev",
    "fetch": "node scripts/fetch_gh_data.mjs",
    "lint": "biome lint --write .",
    "lint:fix": "biome check --write .",
    "prettier": "prettier --cache --check '**/*.{ts,js,mjs,json,md,yml,html,css,astro}'",
    "prettier:fix": "prettier --write --cache '**/*.{ts,js,mjs,json,md,yml,html,css,astro}'",
    "preview": "astro preview",
    "start": "astro dev"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-packagejson",
      "prettier-plugin-tailwindcss",
      "prettier-plugin-astro"
    ],
    "tailwindStylesheet": "src/style.css"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@srcery-colors/srcery-palette": "^1.1.0",
    "@tailwindcss/vite": "^4.2.4",
    "astro": "^6.1.8",
    "devicon": "^2.17.0",
    "highlight.js": "^11.11.1",
    "simple-icons": "^16.17.0",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@octokit/types": "16.0.0",
    "@types/lodash": "4.17.24",
    "globals": "17.5.0",
    "lodash": "4.18.1",
    "octokit": "5.0.5",
    "prettier": "3.8.3",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-packagejson": "3.0.2",
    "prettier-plugin-tailwindcss": "0.7.2",
    "typescript": "^6.0.3"
  }
}

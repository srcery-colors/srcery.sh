{
  "name": "srcery-colors-website",
  "version": "5.0.0",
  "private": true,
  "description": "Srcery theme landing page",
  "homepage": "https://srcery.sh",
  "repository": {
    "type": "git",
    "url": "https://github.com/srcery-colors/srcery.sh"
  },
  "license": "MIT",
  "author": "Srcery Team",
  "type": "module",
  "browser": true,
  "scripts": {
    "astro:check": "astro check && tsc --noEmit",
    "biome:check": "biome check --write .",
    "biome:ci": "biome ci",
    "biome:format": "biome format --write .",
    "biome:lint": "biome lint --write .",
    "build": "astro build",
    "prebuild:ci": "node scripts/fetch_gh_data.mjs",
    "build:ci": "astro build",
    "clean": "rm -f src/github.json",
    "dev": "astro dev",
    "fetch": "node scripts/fetch_gh_data.mjs",
    "prettier": "prettier --cache --check '**/*.{ts,js,mjs,json,md,yml,html,css,astro}'",
    "prettier:fix": "prettier --write --cache '**/*.{ts,js,mjs,json,md,yml,html,css,astro}'",
    "preview": "astro preview",
    "start": "astro dev"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-packagejson",
      "prettier-plugin-tailwindcss",
      "prettier-plugin-astro"
    ],
    "tailwindStylesheet": "src/style.css"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@srcery-colors/srcery-palette": "^2.0.0",
    "devicon": "^2.17.0",
    "highlight.js": "^11.11.1",
    "simple-icons": "^16.18.0",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@biomejs/biome": "2.5.4",
    "@octokit/types": "16.0.0",
    "@tailwindcss/vite": "4.3.3",
    "@types/lodash": "4.17.24",
    "astro": "7.0.9",
    "lodash": "4.18.1",
    "octokit": "5.0.5",
    "prettier": "3.9.5",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-packagejson": "3.0.2",
    "prettier-plugin-tailwindcss": "0.8.1",
    "typescript": "6.0.3"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "26",
      "onFail": "warn"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "11",
      "onFail": "download"
    }
  }
}
